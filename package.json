{
  "name": "intelli-mock-monorepo",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "clean": "pnpm -r clean",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r --parallel test:watch",
    "test:coverage": "pnpm -r test:coverage",
    "test:integration": "pnpm --filter @intelli-mock/core test:integration",
    "test:e2e": "pnpm --filter @intelli-mock/ui test:e2e"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitest/coverage-v8": "^4.1.4",
    "ts-node": "^10.9.0",
    "typescript": "^5.7.0"
  }
}
