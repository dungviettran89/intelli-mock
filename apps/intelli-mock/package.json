{
  "name": "intelli-mock",
  "version": "0.0.0",
  "private": true,
  "bin": {
    "intelli-mock": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "vitest run --config test/vitest.config.ts"
  },
  "dependencies": {
    "commander": "^13.0.0",
    "@intelli-mock/core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.4"
  }
}
