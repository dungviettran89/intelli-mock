{
  "name": "@intelli-mock/core",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config test/integration/vitest.integration.config.ts",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.config.ts"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.52",
    "ai": "^6.0.154",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.4.0",
    "reflect-metadata": "^0.2.0",
    "sql.js": "^1.12.0",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.0",
    "vitest": "^4.1.4"
  }
}
