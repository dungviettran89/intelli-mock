{
  "name": "@intelli-mock/core",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --build",
    "clean": "tsc --build --clean",
    "typecheck": "tsc --noEmit",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/database/data-source.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.config.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.3",
    "mariadb": "^3.4.0",
    "reflect-metadata": "^0.2.0",
    "sql.js": "^1.12.0",
    "tsyringe": "^4.8.0",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@types/express": "^4.17.0",
    "@types/jsonwebtoken": "^9.0.10",
    "ts-node": "^10.9.0"
  }
}
